* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Arial', sans-serif;
}

body {
    background-color: #f4f7f6;
    color: #333;
    line-height: 1.6;
}

.container {
    max-width: 1100px;
    margin: auto;
    padding: 0 20px;
}

/* Header */
.main-header {
    background: #ffffff;
    padding: 20px 0;
    border-bottom: 2px solid #0056b3;
}

.main-header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-weight: bold;
    font-size: 1.5rem;
    color: #0056b3;
}

nav ul {
    display: flex;
    list-style: none;
}

nav ul li {
    margin-left: 20px;
}

nav ul li a {
    text-decoration: none;
    color: #333;
    font-weight: 600;
}

/* Hero Section */
.hero-section {
    background: #eef2f3;
    padding: 80px 0;
    text-align: center;
    border-bottom: 1px solid #ddd;
}

.hero-section h1 {
    font-size: 3rem;
    margin-bottom: 10px;
}

.cta-button {
    margin-top: 20px;
    padding: 10px 25px;
    background: #0056b3;
    color: white;
    border: none;
    cursor: pointer;
    font-weight: bold;
}

/* Content Grid */
.content-grid {
    padding: 50px 0;
}

.grid-wrapper {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}

.card {
    background: white;
    padding: 20px;
    border: 1px solid #ccc;
    text-align: center;
}

.image-placeholder {
    height: 150px;
    background: #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
}

/* Footer */
.main-footer {
    background: #333;
    color: white;
    padding: 40px 0;
    text-align: center;
    font-size: 0.9rem;
}
